{{#if images}}
{{#if images.length}}
<div style="margin-top: 15px;">
  <h3 style="font-size: 14px; color: #374151; border-bottom: 1px solid #e5e7eb; padding-bottom: 5px; margin-bottom: 10px;">{{title}}</h3>
  <div style="display: flex; flex-wrap: wrap; gap: 8px;">
    {{#each images}}
    <div style="width: 32%; box-sizing: border-box;">
      <img src="{{this.src}}" alt="{{this.fileName}}" style="width: 100%; height: 180px; object-fit: cover; border: 1px solid #e5e7eb; border-radius: 4px;" />
    </div>
    {{/each}}
  </div>
</div>
{{/if}}
{{/if}}
