<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Quote - {{jobNumber}}</title>
  <style>
    body { font-family: sans-serif; color: #333; line-height: 1.6; }
    .header { border-bottom: 2px solid #2563eb; padding-bottom: 10px; margin-bottom: 20px; }
    .title { font-size: 24px; font-weight: bold; color: #1e40af; }
    .details { margin-bottom: 20px; }
    .details th { text-align: left; padding-right: 20px; color: #6b7280; }
    .content { margin-top: 30px; }
    .price { font-size: 20px; font-weight: bold; margin-top: 20px; border-top: 1px solid #ccc; padding-top: 10px; }
  </style>
</head>
<body>
  <div class="header">
    <div class="title">Quotation</div>
  </div>
  <table class="details">
    <tr><th>Job Number:</th><td>{{jobNumber}}</td></tr>
    <tr><th>Date:</th><td>{{date}}</td></tr>
    <tr><th>Client:</th><td>{{clientName}}</td></tr>
    <tr><th>Property:</th><td>{{propertyAddress}}</td></tr>
  </table>
  <div class="content">
    <h3>Description of Work</h3>
    <p>{{description}}</p>
  </div>
  <div class="price">
    Total Quoted Value: £{{quotedValue}}
  </div>
</body>
</html>
