<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Job Sheet - {{jobNumber}}</title>
  <style>
    body { font-family: sans-serif; color: #333; line-height: 1.6; }
    .header { border-bottom: 2px solid #059669; padding-bottom: 10px; margin-bottom: 20px; }
    .title { font-size: 24px; font-weight: bold; color: #047857; }
    .details { margin-bottom: 20px; width: 100%; border-collapse: collapse; }
    .details th, .details td { text-align: left; padding: 8px; border: 1px solid #e5e7eb; }
    .details th { background: #f9fafb; color: #6b7280; width: 30%; }
    .section { margin-top: 30px; }
    .section h3 { border-bottom: 1px solid #e5e7eb; padding-bottom: 5px; }
  </style>
</head>
<body>
  <div class="header">
    <div class="title">Job Sheet</div>
  </div>
  <table class="details">
    <tr><th>Job Number</th><td>{{jobNumber}}</td></tr>
    <tr><th>Scheduled Date</th><td>{{scheduledDate}}</td></tr>
    <tr><th>Assigned Contractor</th><td>{{contractorName}}</td></tr>
    <tr><th>Property Address</th><td>{{propertyAddress}}</td></tr>
    <tr><th>Tenant Name</th><td>{{tenantName}}</td></tr>
    <tr><th>Tenant Phone</th><td>{{tenantPhone}}</td></tr>
    <tr><th>Key Location / Access Notes</th><td>{{accessNotes}}</td></tr>
  </table>
  <div class="section">
    <h3>Job Description</h3>
    <p>{{description}}</p>
  </div>
  <div class="section">
    <h3>Diagnostic Notes</h3>
    <p>{{diagnosticNotes}}</p>
  </div>
</body>
</html>
