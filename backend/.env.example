# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/affinity?schema=public&connection_limit=5"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=7d

# ─── Magic Link ───────────────────────────────────────────────────────────────
MAGIC_LINK_EXPIRES_MINUTES=15
APP_URL=http://localhost:3000

# ─── Email — SMTP over port 587 ───────────────────────────────────────────────
# Brevo:  SMTP_HOST=smtp-relay.brevo.com, SMTP_USER=<login email>, SMTP_PASS=<SMTP key>
# Resend: SMTP_HOST=smtp.resend.com,       SMTP_USER=resend,        SMTP_PASS=<API key>
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login@example.com
SMTP_PASS=your-smtp-api-key
EMAIL_FROM=noreply@affinity.example.com
EMAIL_FROM_NAME=Affinity Workspace

# ─── OCI Object Storage (S3-compatible) ───────────────────────────────────────
# Find your namespace and region in the OCI console.
# Endpoint format: https://<namespace>.compat.objectstorage.<region>.oraclecloud.com
OCI_ENDPOINT=https://your-namespace.compat.objectstorage.us-ashburn-1.oraclecloud.com
OCI_REGION=us-ashburn-1
OCI_BUCKET_NAME=affinity-media
# Create a Customer Secret Key in OCI IAM for S3-compatible access
OCI_ACCESS_KEY_ID=your-oci-access-key-id
OCI_SECRET_ACCESS_KEY=your-oci-secret-access-key
# How long media signed URLs stay valid (seconds). Default 3600 = 1 hour.
SIGNED_URL_EXPIRES_SECONDS=3600
